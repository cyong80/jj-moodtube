# === jj-moodtube 환경변수 템플릿 ===
# 1. 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채우세요.
# 2. .env.local 은 절대 Git에 커밋·공유하지 마세요. (.gitignore 대상)
# 3. 노출 시: Google API 콘솔·Supabase 등에서 즉시 키 재발급 후 .env.local 업데이트

# --- Google Gemini API ---
GOOGLE_GEMINI_API_KEY=

# --- YouTube Data API ---
YOUTUBE_API_KEY=

# --- NextAuth ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Prisma / Supabase DB ---
# Transaction pooler (서버리스): port 6543 + ?pgbouncer=true
# Session pooler (마이그레이션): port 5432
DATABASE_URL=
DIRECT_URL=
